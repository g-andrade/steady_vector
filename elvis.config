% -*- mode: erlang; -*- vim: set ft=erlang:
[
    {config, [
        #{
            files => ["src/**/*.erl"],
            ruleset => erl_files,
            rules => [
                % This module deliberately uses lowercase macros: guard-style
                % helpers (?is_vector, ?is_index, ...) that read like BIF guards,
                % plain constants (?shift, ?block_size, ?mask) and error helpers
                % (?arg_error, ?vec_error, ...). Allow lowercase as well as the
                % conventional uppercase spelling.
                {elvis_style, macro_naming_convention, #{
                    regex => "^([a-z](_?[a-z0-9]+)*|[A-Z](_?[A-Z0-9]+)*)$"
                }}
            ]
        },
        #{
            files => ["test/**/*.erl"],
            ruleset => erl_files,
            rules => [
                % Test cases legitimately share structure (build a vector, assert
                % over it); don't flag the repetition.
                {elvis_style, dont_repeat_yourself, disable}
            ]
        },
        #{
            files => ["rebar.config", "elvis.config"],
            ruleset => rebar_config
        }
    ]},
    {verbose, false}
].
